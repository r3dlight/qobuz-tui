{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:window:allow-set-size",
    "core:window:allow-set-always-on-top",
    "core:window:allow-inner-size",
    "core:window:allow-set-resizable"
  ]
}
